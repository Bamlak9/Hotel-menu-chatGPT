# ============================================
# HOTEL MENU WEBSITE - .gitignore
# Static PWA - No Node.js dependencies
# ============================================

# --- Node.js (not needed, but prevents accidents) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package.json
package-lock.json
yarn.lock

# --- macOS / Windows system files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Editor files and folders ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- Logs and temporary files ---
*.log
*.tmp
*.temp
*.cache

# --- Environment variables (if any in future) ---
.env
.env.local
.env.*.local

# --- Backup files ---
*.bak
*.backup
*.old

# --- Build outputs (not used, but safe) ---
dist/
build/
out/

# --- Coverage reports (if testing later) ---
coverage/
.nyc_output/

# --- Optional: Images generated or downloaded ---
images/temp/
*.generated.jpg

# --- Keep your local storage simulation (don't commit) ---
localStorage-simulator/
*.sqlite
*.db